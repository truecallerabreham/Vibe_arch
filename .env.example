# GitHub Personal Access Token — REQUIRED (avoids 60 req/hr anonymous limit)
GITHUB_TOKEN=ghp_your_token_here

# LLM provider: glm (default) | gemini | groq
LLM_PROVIDER=glm

# Provider keys (fill the one matching LLM_PROVIDER)
GLM_API_KEY=your_zhipu_key_here
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here
